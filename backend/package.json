{
  "name": "iphigenai-backend",
  "version": "0.1.0",
  "private": true,
  "description": "IphigenAI 2.0 backend — Fastify + Postgres + Mongo + Redis",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start:api": "node dist/index.js",
    "start:worker": "node dist/worker.js",
    "dev:api": "tsx watch src/index.ts",
    "dev:worker": "tsx watch src/worker.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "seed": "tsx src/seed/run.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/sensible": "^6.0.1",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.0.1",
    "ioredis": "^5.4.2",
    "mongodb": "^6.12.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "drizzle-kit": "^0.30.1",
    "pino-pretty": "^13.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
